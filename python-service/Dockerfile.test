# Production-ready Dockerfile for testing the N+1 query fix in the `/api/orders` endpoint

# Use an official Python runtime as a parent image
FROM python:3.9-slim

# Set the working directory in the container
WORKDIR /app

# Copy the requirements file first to leverage Docker cache
COPY requirements.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt && pip install flask==2.2.5 werkzeug==2.2.3

# Copy the rest of the application
COPY . .

# Set environment variables
ENV FLASK_APP=run.py
ENV FLASK_ENV=testing

# Expose the port the app runs on
EXPOSE 5000

# Command to run tests
CMD ["pytest", "tests/test_orders.py", "-v"]